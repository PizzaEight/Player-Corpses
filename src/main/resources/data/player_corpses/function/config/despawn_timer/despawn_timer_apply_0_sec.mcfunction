execute as @e[type=minecraft:text_display,tag=player_corpses.corpse,scores={despawn_timer_seconds=..0},tag=player_corpses.1] if score @s despawn_timer matches ..0 on vehicle at @s unless score Config has_gore matches 1 run function player_corpses:config/despawn_timer/despawn
