##timer

execute unless score Config despawn_timer matches 1.. if entity @s[type=mannequin,tag=player_corpses.corpse] if score @s[type=mannequin,tag=player_corpses.corpse] player_corpses.time matches 1.. run tellraw @a[scores={corpse_finder=1..}] [{"bold":true,"color":"green","text":"Created "},{"score":{"name":"@s","objective":"player_corpses.time"}}," minute(s) ago "]
execute unless score Config despawn_timer matches 1.. if entity @s[type=mannequin,tag=player_corpses.corpse] unless score @s[type=mannequin,tag=player_corpses.corpse] player_corpses.time matches 1.. run tellraw @a[scores={corpse_finder=1..}] [{"bold":true,"color":"green","text":"Created 0 minute(s) ago "}]

#timer zombie

execute if score @s[type=armor_stand,tag=player_corpses.corpse] player_corpses.time matches 1.. run tellraw @a[scores={corpse_finder=1..}] [{"bold":true,"color":"green","text":"Created "},{"score":{"name":"@s","objective":"player_corpses.time"}}," minute(s) ago ",{"bold":true,"color":"dark_red","text":"Zombified"}]
execute unless score @s[type=armor_stand,tag=player_corpses.corpse] player_corpses.time matches 1.. run tellraw @a[scores={corpse_finder=1..}] [{"bold":true,"color":"green","text":"Created 0 minute(s) ago "},{"bold":true,"color":"dark_red","text":"Zombified"}]

#timer despawn

