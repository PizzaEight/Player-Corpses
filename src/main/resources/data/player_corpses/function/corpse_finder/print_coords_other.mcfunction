execute unless score @n[type=text_display,tag=player_corpses.corpse,tag=player_corpses.1] despawn_timer matches 0 if score Config despawn_timer matches 1.. if entity @s[type=mannequin,tag=player_corpses.corpse] unless score @s[type=mannequin,tag=player_corpses.corpse] player_corpses.time matches 1.. run tellraw @a[scores={corpse_finder=1..}] [{"bold":true,"color":"green","text":"Created 0 minute(s) ago "},{"bold":false,"color":"red","text":"Despawns in "},{"bold":false,"color":"red","score":{"name":"@n[type=text_display,tag=player_corpses.corpse,tag=player_corpses.1]","objective":"despawn_timer"}},{"bold":false,"color":"red","text":" minute(s)"}]

